#!/usr/bin/env python3

from __future__ import annotations

import argparse
import itertools
import json
import math
import os
import re
import shutil
import sys
from pathlib import Path


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Generate a design-space directory of .properties files by combining the values "
            "listed in a JSON parameter space."
        )
    )
    parser.add_argument("base_properties", help="Base .properties file to include from each generated config")
    parser.add_argument("parameter_space", help="JSON file describing the parameter value sets")
    parser.add_argument(
        "--output-dir",
        help=(
            "Destination directory. Defaults to <base_stem>_<json_stem> next to the base properties file."
        ),
    )
    parser.add_argument(
        "--force",
        action="store_true",
        help="Replace the output directory if it already exists.",
    )
    return parser.parse_args()


def load_parameter_space(parameter_space_path: Path) -> tuple[list[str], dict[str, list[str]]]:
    try:
        payload = json.loads(parameter_space_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise ValueError(
            f"Invalid JSON in {parameter_space_path}: line {exc.lineno}, column {exc.colno}: {exc.msg}"
        ) from exc

    if isinstance(payload, dict) and "parameters" in payload:
        raw_parameters = payload["parameters"]
    else:
        raw_parameters = payload

    if not isinstance(raw_parameters, dict) or not raw_parameters:
        raise ValueError(
            "Parameter space must be a non-empty object, or an object with a non-empty 'parameters' object."
        )

    ordered_names: list[str] = []
    normalized_parameters: dict[str, list[str]] = {}

    for raw_name, raw_values in raw_parameters.items():
        if not isinstance(raw_name, str) or not raw_name.strip():
            raise ValueError("Every parameter name must be a non-empty string.")
        if not isinstance(raw_values, list) or not raw_values:
            raise ValueError(f"Parameter '{raw_name}' must provide a non-empty JSON array of values.")

        ordered_names.append(raw_name)
        normalized_parameters[raw_name] = [stringify_property_value(raw_name, value) for value in raw_values]

    return ordered_names, normalized_parameters


def stringify_property_value(parameter_name: str, value: object) -> str:
    if value is None:
        raise ValueError(f"Parameter '{parameter_name}' cannot contain null values.")
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, (int, float)):
        return json.dumps(value, ensure_ascii=True, separators=(",", ":"))
    if isinstance(value, str):
        return value
    raise ValueError(
        f"Parameter '{parameter_name}' contains an unsupported value type: {type(value).__name__}. "
        "Only strings, numbers, and booleans are supported."
    )


def default_output_dir(base_properties_path: Path, parameter_space_path: Path) -> Path:
    return base_properties_path.parent / f"{base_properties_path.stem}_{parameter_space_path.stem}"


def sanitize_fragment(text: str) -> str:
    fragment = re.sub(r"[^A-Za-z0-9]+", "-", text.strip()).strip("-").lower()
    return fragment or "value"


def build_file_name(index: int, total: int, overrides: dict[str, str]) -> str:
    width = max(4, len(str(total)))
    parts = [f"{sanitize_fragment(name)}-{sanitize_fragment(value)}" for name, value in overrides.items()]
    descriptive_name = f"cfg_{index:0{width}d}__{'__'.join(parts)}.properties"
    if len(descriptive_name) <= 160:
        return descriptive_name
    return f"cfg_{index:0{width}d}.properties"


def write_properties_file(
    destination: Path,
    *,
    include_path: str,
    base_properties_path: Path,
    parameter_space_path: Path,
    index: int,
    total: int,
    overrides: dict[str, str],
) -> None:
    lines = [
        "# Generated by uv_dse_gen",
        f"# Base config: {base_properties_path.name}",
        f"# Parameter space: {parameter_space_path.name}",
        f"# Combination: {index}/{total}",
        f"# Overrides: {', '.join(f'{key}={value}' for key, value in overrides.items())}",
        f"@include={include_path}",
        "",
    ]
    for key, value in overrides.items():
        lines.append(f"{key}={value}")
    lines.append("")
    destination.write_text("\n".join(lines), encoding="utf-8")


def ensure_output_directory(output_dir: Path, force: bool) -> None:
    if not output_dir.exists():
        output_dir.mkdir(parents=True)
        return

    if not output_dir.is_dir():
        raise ValueError(f"Output path exists but is not a directory: {output_dir}")

    if not force:
        raise ValueError(f"Output directory already exists: {output_dir} (use --force to replace it)")

    shutil.rmtree(output_dir)
    output_dir.mkdir(parents=True)


def generate_design_space(
    base_properties_path: Path,
    parameter_space_path: Path,
    output_dir: Path,
    *,
    force: bool,
) -> dict[str, object]:
    parameter_order, parameters = load_parameter_space(parameter_space_path)
    ensure_output_directory(output_dir, force)

    combination_values = [parameters[name] for name in parameter_order]
    include_path = Path(os.path.relpath(base_properties_path.resolve(), output_dir.resolve())).as_posix()

    generated_files: list[dict[str, object]] = []
    total = math.prod(len(values) for values in combination_values)

    for index, values in enumerate(itertools.product(*combination_values), start=1):
        overrides = dict(zip(parameter_order, values))
        file_name = build_file_name(index, total, overrides)
        destination = output_dir / file_name
        write_properties_file(
            destination,
            include_path=include_path,
            base_properties_path=base_properties_path,
            parameter_space_path=parameter_space_path,
            index=index,
            total=total,
            overrides=overrides,
        )
        generated_files.append(
            {
                "index": index,
                "file": file_name,
                "overrides": overrides,
            }
        )

    manifest = {
        "tool": "uv_dse_gen",
        "base_properties": str(base_properties_path.resolve()),
        "parameter_space": str(parameter_space_path.resolve()),
        "output_dir": str(output_dir.resolve()),
        "total_combinations": total,
        "parameters": [{"name": name, "values": parameters[name]} for name in parameter_order],
        "generated_files": generated_files,
    }
    (output_dir / "manifest.json").write_text(json.dumps(manifest, indent=2), encoding="utf-8")
    return manifest


def main() -> int:
    args = parse_args()
    base_properties_path = Path(args.base_properties).expanduser().resolve()
    parameter_space_path = Path(args.parameter_space).expanduser().resolve()

    if not base_properties_path.is_file():
        print(f"Base properties file not found: {base_properties_path}", file=sys.stderr)
        return 1
    if base_properties_path.suffix.lower() != ".properties":
        print(f"Base properties file must end with .properties: {base_properties_path}", file=sys.stderr)
        return 1
    if not parameter_space_path.is_file():
        print(f"Parameter space JSON file not found: {parameter_space_path}", file=sys.stderr)
        return 1

    if args.output_dir:
        output_dir = Path(args.output_dir).expanduser().resolve()
    else:
        output_dir = default_output_dir(base_properties_path, parameter_space_path).resolve()

    try:
        manifest = generate_design_space(
            base_properties_path,
            parameter_space_path,
            output_dir,
            force=args.force,
        )
    except (OSError, ValueError) as exc:
        print(str(exc), file=sys.stderr)
        return 1

    print(f"Generated {manifest['total_combinations']} properties files in {output_dir}")
    print(f"Manifest: {output_dir / 'manifest.json'}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
